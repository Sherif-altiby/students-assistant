generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Gender {
  MALE 
  FEMALE 
}

enum EducationLevel {
  GENERAL_SECONDARY // ثانوية عامة
  AZHARI_SECONDARY // ثانوية أزهرية
}

enum Track {
  SCIENCE_MATH // علمي رياضة (عامة فقط)
  SCIENCE_SCIENCE // علمي علوم (عامة فقط)
  SCIENCE // علمي (أزهرية فقط)
  LITERARY // أدبي (عامة وأزهرية)
}

enum StudyTableType {
  DATE_RANGE
  NUMBER_OF_DAYS
}

model User {
  id          String         @id @default(uuid())
  name        String
  email       String         @unique
  phone       String         @unique @default("0000000000")
  password    String
  gender      Gender
  level       EducationLevel
  track       Track
  parentPhone String         @unique @map("parent_phone")
  country     String

  habits Habit[]
  tasks  Task[]

  studyTables       StudyTable[]
  lessonCompletions StudyLessonCompletion[]

  completedTasks  CompletedTask[]
  completedHabits CompletedHabit[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

enum TaskFrequency {
  TODAY
  EVERY_DAY
}

model Task {
  id        String        @id @default(uuid())
  title     String
  frequency TaskFrequency @default(TODAY)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  completions CompletedTask[]

  @@index([userId])
  @@map("tasks")
}

model CompletedTask {
  id String @id @default(uuid())

  date DateTime @db.Date

  completedAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([taskId, date])
  @@index([userId])
  @@index([taskId])
  @@map("completed_tasks")
}

model Habit {
  id    String @id @default(uuid())
  title String

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  completions CompletedHabit[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@map("habits")
}

model CompletedHabit {
  id String @id @default(uuid())

  date DateTime @db.Date

  completedAt DateTime @default(now()) @map("completed_at")

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  habitId String @map("habit_id")
  habit   Habit  @relation(fields: [habitId], references: [id], onDelete: Cascade)

  @@unique([habitId, date])
  @@index([userId])
  @@index([habitId])
  @@map("completed_habits")
}

model StudyTable {
  id String @id @default(uuid())

  title String

  type StudyTableType

  startDate DateTime @db.Date
  endDate   DateTime @db.Date

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  days StudyDay[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("study_tables")
}

model StudyDay {
  id String @id @default(uuid())

  date DateTime @db.Date

  studyTableId String     @map("study_table_id")
  studyTable   StudyTable @relation(fields: [studyTableId], references: [id], onDelete: Cascade)

  subjects StudySubject[]

  createdAt DateTime @default(now())

  @@unique([studyTableId, date])
  @@index([studyTableId])
  @@map("study_days")
}

model StudySubject {
  id String @id @default(uuid())

  title String

  dayId String   @map("day_id")
  day   StudyDay @relation(fields: [dayId], references: [id], onDelete: Cascade)

  chapters StudyChapter[]

  createdAt DateTime @default(now())

  @@index([dayId])
  @@map("study_subjects")
}

model StudyChapter {
  id String @id @default(uuid())

  title String

  subjectId String       @map("subject_id")
  subject   StudySubject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  lessons StudyLesson[]

  createdAt DateTime @default(now())

  @@index([subjectId])
  @@map("study_chapters")
}

model StudyLesson {
  id String @id @default(uuid())

  title String

  chapterId String       @map("chapter_id")
  chapter   StudyChapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  completions StudyLessonCompletion[]

  createdAt DateTime @default(now())

  @@index([chapterId])
  @@map("study_lessons")
}

model StudyLessonCompletion {
  id String @id @default(uuid())

  completedAt DateTime @default(now())

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  lessonId String      @map("lesson_id")
  lesson   StudyLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([lessonId])
  @@index([userId])
  @@index([lessonId])
  @@map("study_lesson_completions")
}
