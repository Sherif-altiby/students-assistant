// prisma/models/user.prisma
model User {
  id          String         @id @default(uuid())
  name        String
  email       String         @unique
  phone       String         @unique @default("0000000000")
  password    String
  gender      Gender
  level       EducationLevel
  track       Track
  parentPhone String         @unique @map("parent_phone")
  country     String

  habits Habit[]
  tasks  Task[]

  studyTables       StudyTable[]
  lessonCompletions StudyLessonCompletion[]

  completedHabits CompletedHabit[]

  taskHistories TaskHistory[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}